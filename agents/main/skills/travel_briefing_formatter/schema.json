{
  "skill_id": "travel_briefing_formatter",
  "name": "出行建议格式化",
  "description": "将路线和天气组合成结构化出行建议。",
  "executor": {
    "type": "code",
    "name": "travel_briefing_formatter"
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "origin_address": {"type": "string"},
      "destination_address": {"type": "string"},
      "route": {"type": "object"},
      "weather": {"type": "object"}
    },
    "required": ["origin_address", "destination_address", "route", "weather"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
