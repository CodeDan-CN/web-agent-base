{
  "skill_id": "amap_route_weather_plan",
  "name": "高德路线天气出行建议",
  "description": "地址解析、驾车路线、目的地天气和出行建议的固定链路。",
  "executor": {
    "type": "chain",
    "chain_id": "amap_route_weather_plan"
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "origin_address": {
        "type": "string",
        "description": "用户明确给出的出发地地址，不能使用当前位置、默认位置、未知地点等占位内容。"
      },
      "destination_address": {
        "type": "string",
        "description": "用户明确给出的目的地地址。"
      },
      "city": {
        "type": "string",
        "description": "用户明确给出的城市，用于提升地址解析稳定性。"
      },
      "route_extensions": {
        "type": "string",
        "enum": ["base", "all"],
        "description": "路径规划返回详情级别。"
      },
      "weather_extensions": {
        "type": "string",
        "enum": ["base", "all"],
        "description": "天气查询类型，base 为实时天气，all 为天气预报。"
      }
    },
    "required": ["origin_address", "destination_address"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
