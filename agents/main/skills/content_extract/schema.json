{
  "skill_id": "content_extract",
  "name": "文本提取",
  "description": "从用户提供的文本中提取摘要、关键要点或结构化大纲。",
  "executor": {
    "type": "code",
    "name": "content_extract"
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "content": {
        "type": "string",
        "description": "需要处理的原始文本"
      },
      "extract_mode": {
        "type": "string",
        "enum": ["key_points", "summary", "outline"],
        "description": "提取方式"
      }
    },
    "required": ["content"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
