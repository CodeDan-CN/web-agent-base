{
  "skill_id": "amap_route_walking",
  "name": "高德步行路径规划",
  "description": "调用高德步行路径规划接口，根据起终点经纬度查询步行路线。",
  "executor": {
    "type": "api",
    "endpoint": "https://restapi.amap.com/v3/direction/walking",
    "method": "GET",
    "auth": {
      "type": "query",
      "param": "key",
      "env": "AMAP_WEB_SERVICE_KEY"
    },
    "timeout_ms": 10000,
    "response_mapping": {
      "kind": "amap_generic"
    }
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "origin": {"type": "string"},
      "destination": {"type": "string"}
    },
    "required": ["origin", "destination"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
