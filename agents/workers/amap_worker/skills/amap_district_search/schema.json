{
  "skill_id": "amap_district_search",
  "name": "高德行政区域查询",
  "description": "调用高德行政区域查询接口，获取行政区编码和层级信息。",
  "executor": {
    "type": "api",
    "endpoint": "https://restapi.amap.com/v3/config/district",
    "method": "GET",
    "auth": {
      "type": "query",
      "param": "key",
      "env": "AMAP_WEB_SERVICE_KEY"
    },
    "timeout_ms": 10000,
    "response_mapping": {
      "kind": "amap_generic"
    }
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "keywords": {"type": "string"},
      "subdistrict": {"type": "string"},
      "extensions": {"type": "string", "enum": ["base", "all"]}
    },
    "required": ["keywords"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
