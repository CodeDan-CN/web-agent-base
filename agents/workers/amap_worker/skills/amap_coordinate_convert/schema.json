{
  "skill_id": "amap_coordinate_convert",
  "name": "高德坐标转换",
  "description": "调用高德坐标转换接口，将其他坐标系转换为高德坐标。",
  "executor": {
    "type": "api",
    "endpoint": "https://restapi.amap.com/v3/assistant/coordinate/convert",
    "method": "GET",
    "auth": {
      "type": "query",
      "param": "key",
      "env": "AMAP_WEB_SERVICE_KEY"
    },
    "timeout_ms": 10000,
    "response_mapping": {
      "kind": "amap_generic"
    }
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "locations": {"type": "string", "description": "坐标列表，格式为 lng,lat，可用 | 分隔多个"},
      "coordsys": {"type": "string", "enum": ["gps", "mapbar", "baidu", "autonavi"]}
    },
    "required": ["locations", "coordsys"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
