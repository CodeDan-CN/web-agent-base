{
  "skill_id": "amap_route_distance",
  "name": "高德距离测量",
  "description": "调用高德距离测量接口，计算起点和终点坐标之间的距离。",
  "executor": {
    "type": "api",
    "base_url_env": "AMAP_WEB_SERVICE_BASE_URL",
    "endpoint": "/v3/distance",
    "method": "GET",
    "auth": {
      "type": "query",
      "param": "key",
      "env": "AMAP_WEB_SERVICE_KEY"
    },
    "timeout_ms": 10000,
    "response_mapping": {
      "kind": "amap_generic"
    }
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "origins": {"type": "string"},
      "destination": {"type": "string"},
      "type": {"type": "string"}
    },
    "required": ["origins", "destination"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
