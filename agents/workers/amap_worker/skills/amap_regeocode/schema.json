{
  "skill_id": "amap_regeocode",
  "name": "高德逆地址解析",
  "description": "调用高德逆地理编码接口，将经纬度转换为结构化地址。",
  "executor": {
    "type": "api",
    "endpoint": "https://restapi.amap.com/v3/geocode/regeo",
    "method": "GET",
    "auth": {
      "type": "query",
      "param": "key",
      "env": "AMAP_WEB_SERVICE_KEY"
    },
    "timeout_ms": 10000,
    "response_mapping": {
      "kind": "amap_generic"
    }
  },
  "input_schema": {
    "type": "object",
    "properties": {
      "location": {"type": "string", "description": "经纬度，格式为 lng,lat"},
      "extensions": {"type": "string", "enum": ["base", "all"]}
    },
    "required": ["location"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["success", "partial_success", "missing_params", "failed"]},
      "data": {"type": "object"},
      "summary": {"type": "string"},
      "missing_params": {"type": "array", "items": {"type": "string"}},
      "error": {"type": ["string", "null"]}
    },
    "required": ["status", "data", "summary", "missing_params", "error"],
    "additionalProperties": false
  }
}
